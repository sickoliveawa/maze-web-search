# ============================================================
# maze-web .gitignore
# ============================================================
# Tracks: src/, scripts/, tools/, README/LICENSE, sweep data (for
#         reviewer reproducibility), ckpt (selected top results), maze_seal/
# Ignores: paper/ (manuscript drafts + build artifacts), LaTeX build, IDE noise

# ------------------------------------------------------------
# 1. Paper / manuscript drafts (excluded from repo — paper is separate)
# ------------------------------------------------------------
# Whole paper/ tree: LaTeX source + sections + figures + build artifacts.
# Top1 ckpt for each sweep run is duplicated in ckpt/ for reviewer access.
paper/
paper_figs/
paper_preview/

# ------------------------------------------------------------
# 2. Figure drafts / exploratory plots (not shipped)
# ------------------------------------------------------------
# LaTeX-side fig cache lives under figures/ and stays local-only.
figures/*

# ------------------------------------------------------------
# 3. Pre-publication backup / scratch dirs
# ------------------------------------------------------------
_before_git_init_*/
_before_*/

# Backup files (any extension containing .bak. or .bak_)
*.bak.*
*.bak_*
*.bak
!*/.gitkeep

# ------------------------------------------------------------
# 4. LaTeX build output (regenerable via xelatex)
# ------------------------------------------------------------
*.aux
*.log
*.out
*.toc
*.synctex.gz
*.fls
*.fdb_latexmk
*.bbl
*.blg

# ------------------------------------------------------------
# 5. Python / Node build artifacts
# ------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
node_modules/
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/

# ------------------------------------------------------------
# 6. Editor / IDE / OS noise
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Local env / secrets
.env
.env.local
*.local
secrets.yaml
*.key
*.pem

# ------------------------------------------------------------
# 7. Diagnostic / one-off scratch (NEVER commit, even with prefix)
# ------------------------------------------------------------
# Convention: ALL diagnostic scripts and screenshots are git-ignored.
# The few we want to KEEP are renamed to drop the leading underscore.
_*.py.tmp
_*.png.tmp

# ------------------------------------------------------------
# 8. Browser / dev-mode cache
# ------------------------------------------------------------
.browserslist
.babel-cache
.parcel-cache/
.vite/
dist/
build/

# ------------------------------------------------------------
# 9. Output dirs that are runtime-only
# ------------------------------------------------------------
tmp/
out/
output/