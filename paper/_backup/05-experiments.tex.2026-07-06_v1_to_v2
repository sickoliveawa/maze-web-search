B = $\{3, 4\}$, S = $\{4, 5\}$;\textbf{$F_7$, priority 11}:
cells = $\{(\pm 2, 0), (0, \pm 1)\}$, B = $\{2, 3, 5\}$, S = $\{3, 4, 6\}$),
